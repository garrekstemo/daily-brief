<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.garrek.daily-brief</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/garrek/Developer/daily-brief/scripts/run_brief.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>10</integer>
        <key>Minute</key><integer>30</integer>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/garrek/Developer/daily-brief</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/garrek/.local/bin:/Users/garrek/.juliaup/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>/Users/garrek/Library/Logs/daily-brief/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/garrek/Library/Logs/daily-brief/launchd.err.log</string>
</dict>
</plist>
